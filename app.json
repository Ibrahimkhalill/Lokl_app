{
  "expo": {
    "name": "LOKL",
    "slug": "lokl-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "lokl",
    "userInterfaceStyle": "dark",
    "icon": "./assets/images/ios.png",
    "splash": {
      "image": "./assets/images/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#14161A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.lokl.app",
      "icon": "./assets/images/ios.png"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#14161A"
      },
      "package": "com.lokl.app",
      "edgeToEdgeEnabled": true,
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyDUG5-oxWq1CeJRKcMMJ69AstZhiscurv0"
        }
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-system-ui",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow LOKL to access your photos to set your profile, posts, and event images.",
          "cameraPermission": "Allow LOKL to take photos for your profile, posts, and events."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#232323",
          "image": "./assets/images/splash-icon.png",
          "dark": {
            "image": "./assets/images/splash-icon.png",
            "backgroundColor": "#232323"
          },
          "imageWidth": 200
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8bee028a-8a55-4019-a5d6-a13cfabc6640"
      }
    },
    "owner": "aininja"
  }
}
